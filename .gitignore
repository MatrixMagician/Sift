.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
dist/

# Local working documents — deliberately not published.
# Root-anchored: .claude/CLAUDE.md is tracked and must stay so.
/CLAUDE.md
/SPEC.md

# Per-run scratch from GSD workflows (docs-update manifests, verifier JSON).
# Refills on every run and is never durable planning state — unlike the rest
# of .planning/, which is tracked on purpose.
/.planning/tmp/

# Generated knowledge-graph output (/gsd-graphify, /graphify). Rebuilt from the
# codebase on demand, multi-megabyte, and churns on every build — derived
# artefacts, not source.
/.planning/graphs/
/graphify-out/
